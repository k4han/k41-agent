# OpenAI-compatible LLM provider
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=devstral-2512
LLM_TEMPERATURE=0
# Backward-compatible fallback if LLM_API_KEY is not set
OPENAI_API_KEY=

# Telegram Bot Token (từ @BotFather)
TELEGRAM_BOT_TOKEN=
# true = tự khởi động khi app boot, vẫn có thể start/stop qua dashboard
ENABLE_TELEGRAM=true

# Discord Bot Token
DISCORD_BOT_TOKEN=
# true = tự khởi động khi app boot, vẫn có thể start/stop qua dashboard
ENABLE_DISCORD=true

# App settings
HOST=0.0.0.0
PORT=8000
ENABLE_WEB=true
ENABLE_DASHBOARD=true
ENABLE_API=true
DEFAULT_WORKFLOW=react_agent
DEFAULT_SERVICE_TYPE=default
RECURSION_LIMIT=100

# Persistence (checkpointer-level)
DATABASE_URL=sqlite+aiosqlite:///data/agent_state.db
