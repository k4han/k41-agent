OPENAI_API_KEY=sk-...

# Telegram Bot Token (từ @BotFather)
TELEGRAM_BOT_TOKEN=
# true = tự khởi động khi app boot, vẫn có thể start/stop qua dashboard
ENABLE_TELEGRAM=true

# Discord Bot Token
DISCORD_BOT_TOKEN=
# true = tự khởi động khi app boot, vẫn có thể start/stop qua dashboard
ENABLE_DISCORD=true

# App settings
HOST=0.0.0.0
PORT=8000
ENABLE_WEB=true
ENABLE_DASHBOARD=true
ENABLE_API=true
DEFAULT_WORKFLOW=chat_agent
DEFAULT_SERVICE_TYPE=default
RECURSION_LIMIT=100

# Persistence (checkpointer-level)
DATABASE_URL=sqlite:///data/agent_state.db
